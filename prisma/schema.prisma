generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Team {
  id             String       @id @default(uuid())
  grade          Int
  name           String
  song           String
  topic          String
  color          String
  avatar         String
  lyrics         String
  audioUrl       String?
  isRosterLocked Boolean      @default(false)
  members        Student[]
  teacherVote    TeacherVote?
  votes          Vote[]
}

model Student {
  id        String  @id @default(uuid())
  name      String
  grade     Int
  pin       String
  isCaptain Boolean @default(false)
  teamId    String?
  hasVoted  Boolean @default(false)
  team      Team?   @relation(fields: [teamId], references: [id], onDelete: Restrict)
  votes     Vote[]
}

model Vote {
  id           String   @id @default(cuid())
  studentId    String
  teamId       String
  scienceScore Int
  bangerScore  Int
  createdAt    DateTime @default(now())
  student      Student  @relation(fields: [studentId], references: [id])
  team         Team     @relation(fields: [teamId], references: [id])

  @@unique([studentId, teamId])
}

model TeacherVote {
  id            String @id @default(cuid())
  teamId        String @unique
  contentScore  Int
  accuracyScore Int
  team          Team   @relation(fields: [teamId], references: [id])
}
